{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": false,
    "incremental": true
  },
  "include": ["scripts/**/*.ts", "packages/*/src/**/*.ts"],
  "exclude": ["node_modules", "inkvas-legacy-assets", "**/dist"]
}
